{
    "name": "njames/metric-runner",
    "description": "SQL-first analytics metric runner for Laravel with ClickHouse support",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.11",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Njames\\MetricRunner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Njames\\MetricRunner\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Njames\\MetricRunner\\MetricRunnerServiceProvider"
            ],
            "aliases": {
                "MetricRunner": "Njames\\MetricRunner\\Facades\\MetricRunner"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": false
        }
    },
    "minimum-stability": "stable",
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ]
    }
}
